---
apiVersion: v1
kind: ConfigMap
metadata:
  name: grafana-dashboard-provisioning
  namespace: {{ monitoring_namespace }}
data:
  provider.yaml: |
    apiVersion: 1
    providers:
      - name: 'node-exporter'
        orgId: 1
        folder: ''
        type: file
        disableDeletion: false
        editable: true
        options:
          path: /var/lib/grafana/dashboards
